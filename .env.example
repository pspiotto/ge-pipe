# POSTGRES_HOST is consumed by the Dockerized app, where the database is reached
# at the compose service name `postgres` (NOT localhost). For host-side access
# (e.g. psql), connect to localhost on POSTGRES_PORT instead.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=gepipe
POSTGRES_PASSWORD=gepipe
POSTGRES_DB=ge_pipe
